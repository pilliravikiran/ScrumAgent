# Copy to .env and fill in
ANTHROPIC_API_KEY=

# Ticket mode: "true" = mock tickets (demo without Jira), "false" = real Jira
MOCK_MODE=true

# Only needed when MOCK_MODE=false
JIRA_BASE_URL=https://yourteam.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=MTA
